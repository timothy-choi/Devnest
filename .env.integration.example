# Copy to the repo root as `.env` (Docker Compose loads it automatically):
#   cp .env.integration.example .env
# Then rebuild so Next.js embeds NEXT_PUBLIC_* correctly:
#   docker compose -f docker-compose.integration.yml up -d --build
#
# Replace the host with your public IP/DNS (e.g. sslip.io). Open security groups for 3000 and 8000.
#
# EC2: ``scripts/deploy-ec2.sh`` derives NEXT_PUBLIC_API_BASE_URL from DEVNEST_FRONTEND_PUBLIC_BASE_URL
# when NEXT_PUBLIC_API_BASE_URL is unset (fixes browsers still calling localhost:8000).
#
# Local full-stack (bundled Postgres): omit ``DATABASE_URL`` from this file if it points at RDS, or the
# backend container will use RDS instead of the compose ``postgres`` service. EC2 + RDS: set
# ``DATABASE_URL`` (or ``DEVNEST_COMPOSE_DATABASE_URL``) to the same DSN, or run ``scripts/deploy-ec2.sh``.

DEVNEST_FRONTEND_PUBLIC_BASE_URL=http://98-92-163-201.sslip.io:3000
NEXT_PUBLIC_API_BASE_URL=http://98-92-163-201.sslip.io:8000
