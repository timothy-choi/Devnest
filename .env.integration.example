# =============================================================================
# DevNest integration / EC2 — example environment (NO REAL SECRETS)
# =============================================================================
# Copy to repo root and edit:
#   cp .env.integration.example .env.integration
#
# One-command startup + health checks:
#   ./scripts/deploy_integration.sh
#
# Manual compose (after editing .env.integration):
#   docker compose --env-file .env.integration -f docker-compose.integration.yml up -d --build
#
# Full runbook: docs/INTEGRATION_STARTUP.md
# =============================================================================

# -----------------------------------------------------------------------------
# Local smoke (default posture): bundled Postgres + local snapshot files
# -----------------------------------------------------------------------------
# Omit DATABASE_URL and DEVNEST_COMPOSE_DATABASE_URL to use compose defaults:
#   postgresql+psycopg://devnest:devnest@postgres:5432/devnest_dev
#
# For RDS or any external Postgres, set ONE of the following (same value in
# practice). Use a single-line SQLAlchemy URL (not a bare host= keyword DSN).
#
# Example shape only — replace user, password, host, db, sslmode:
# DATABASE_URL=postgresql+psycopg://devnest_app:CHANGE_ME@db.example.internal:5432/devnest?sslmode=require
#
# DEVNEST_COMPOSE_DATABASE_URL is an alias compose prefers when writing both
# DATABASE_URL and DEVNEST_DATABASE_URL into containers.
# DATABASE_URL=
# DEVNEST_COMPOSE_DATABASE_URL=

# -----------------------------------------------------------------------------
# Public URLs (required for remote browsers, OAuth, and workspace subdomains)
# -----------------------------------------------------------------------------
# Use a hostname you control or sslip.io-style DNS that points at your server.
# Examples use RFC 5737 documentation addresses — replace with your real host.
#
# Browser-visible Next.js origin (scheme + host + port):
DEVNEST_FRONTEND_PUBLIC_BASE_URL=http://localhost:3000

# Browser → FastAPI (often :8000 on the same host as the API):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Wildcard base for workspace routes: ws-<id>.<DEVNEST_BASE_DOMAIN>
# Local same-host browser: app.lvh.me resolves to 127.0.0.1 without /etc/hosts.
DEVNEST_BASE_DOMAIN=app.lvh.me

# Traefik published URL scheme/port (see docker-compose.integration.yml header).
DEVNEST_GATEWAY_PUBLIC_SCHEME=http
DEVNEST_GATEWAY_PUBLIC_PORT=9081

# EC2 example (replace with your public hostname — NOT the values below in prod):
# DEVNEST_FRONTEND_PUBLIC_BASE_URL=http://203-0-113-10.sslip.io:3000
# NEXT_PUBLIC_API_BASE_URL=http://203-0-113-10.sslip.io:8000
# DEVNEST_BASE_DOMAIN=203-0-113-10.sslip.io
# DEVNEST_GATEWAY_PUBLIC_SCHEME=http
# DEVNEST_GATEWAY_PUBLIC_PORT=0

# -----------------------------------------------------------------------------
# OAuth (optional — leave unset to use email/password only)
# -----------------------------------------------------------------------------
# OAuth enables only when client id, secret, AND a non-loopback public callback
# base are all configured. Backend defaults GitHub/Google public bases from
# DEVNEST_FRONTEND_PUBLIC_BASE_URL when explicit bases are unset.
#
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
#
# Optional explicit callback origins (must match provider app settings):
# GITHUB_OAUTH_PUBLIC_BASE_URL=http://localhost:3000
# GCLOUD_OAUTH_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Fail-fast guards (EC2 / RDS — usually set by scripts/deploy-ec2.sh)
# -----------------------------------------------------------------------------
# DEVNEST_EXPECT_EXTERNAL_POSTGRES=true
#   Abort if the resolved DB host is the bundled service name "postgres".
#
# DEVNEST_EXPECT_REMOTE_GATEWAY_CLIENTS=true
#   Abort if DEVNEST_BASE_DOMAIN is a local-only lab domain (e.g. app.lvh.me).
#
# DEVNEST_EXPECT_EXTERNAL_POSTGRES=
# DEVNEST_EXPECT_REMOTE_GATEWAY_CLIENTS=

# -----------------------------------------------------------------------------
# Snapshot archive storage (metadata always in Postgres)
# -----------------------------------------------------------------------------
# Local / bundled Postgres: omit → DEVNEST_SNAPSHOT_STORAGE_PROVIDER defaults to local.
#
# External Postgres OR either expect flag above → S3 is required (validated by
# deploy_integration.sh and application settings).
#
# DEVNEST_SNAPSHOT_STORAGE_PROVIDER=s3
# DEVNEST_S3_SNAPSHOT_BUCKET=your-devnest-snapshots-bucket
# DEVNEST_S3_SNAPSHOT_PREFIX=devnest-snapshots
# AWS_REGION=us-east-1
# Optional explicit keys (otherwise IAM role / instance profile):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional staging directory inside containers for S3 upload/download temp files:
# DEVNEST_SNAPSHOT_TEMP_DIR=/var/lib/devnest/snapshot-staging

# -----------------------------------------------------------------------------
# EC2 autoscaler provisioning (Phase 2 safe scale-out only)
# -----------------------------------------------------------------------------
# Required before POST /internal/autoscaler/provision-one can launch a node.
# The autoscaler still provisions at most one EC2 instance per tick and does not
# drain or terminate nodes automatically.
#
# AWS_REGION=us-east-1
# DEVNEST_AUTOSCALER_ENABLED=true
# DEVNEST_AUTOSCALER_EVALUATE_ONLY=false
# DEVNEST_AUTOSCALER_MIN_NODES=1
# DEVNEST_AUTOSCALER_MAX_NODES=3
# DEVNEST_AUTOSCALER_MIN_IDLE_SLOTS=1
# DEVNEST_AUTOSCALER_MAX_CONCURRENT_PROVISIONING=1
# DEVNEST_AUTOSCALER_SCALE_OUT_COOLDOWN_SECONDS=300
#
# AMI can be a stock Amazon Linux 2023 image. When custom user-data is unset
# and DEVNEST_EC2_BOOTSTRAP_PREBAKED=false, DevNest generates user-data that
# installs Docker, creates /opt/devnest + /var/lib/devnest/workspace-projects,
# and starts a systemd heartbeat service for the autoscaler-assigned node_key.
# DEVNEST_EC2_AMI_ID=ami-0123456789abcdef0
# DEVNEST_EC2_INSTANCE_TYPE=t3.medium
# DEVNEST_EC2_SUBNET_ID=subnet-0123456789abcdef0
# DEVNEST_EC2_SECURITY_GROUP_IDS=sg-0123456789abcdef0
# DEVNEST_EC2_INSTANCE_PROFILE=DevNestExecutionNodeProfile
# DEVNEST_EC2_DEFAULT_EXECUTION_MODE=ssm_docker
# DEVNEST_EC2_SSH_USER_DEFAULT=ubuntu
# DEVNEST_EC2_KEY_NAME=
# DEVNEST_EC2_TAG_PREFIX=devnest
# DEVNEST_EC2_EXTRA_TAGS=env=integration,service=execution-node
# DEVNEST_EC2_WORKSPACE_PROJECTS_BASE=/var/lib/devnest/workspace-projects
#
# Required for generated heartbeat bootstrap. This URL must be reachable from
# the autoscaled EC2 instance, typically a private ALB/NLB/DNS name in the VPC.
# DEVNEST_EC2_HEARTBEAT_INTERNAL_API_BASE_URL=http://10.0.1.20:8000
# INTERNAL_API_KEY_INFRASTRUCTURE=replace-with-infra-scope-key
#
# Bootstrap options:
# 1) Generated Amazon Linux 2023 bootstrap (recommended for stock AL2023 AMIs):
# DEVNEST_EC2_BOOTSTRAP_PREBAKED=false
# DEVNEST_EC2_USER_DATA=
# DEVNEST_EC2_USER_DATA_B64=
#
# 2) Custom cloud-init/user-data supplied by env. Prefer base64 for multi-line scripts.
# The autoscaler replaces {{NODE_KEY}} / {{DEVNEST_NODE_KEY}} before launch.
# DEVNEST_EC2_USER_DATA_B64=<base64-encoded cloud-init or shell script>
#
# 3) Prebaked AMI that already starts Docker and emits /internal/execution-nodes/heartbeat:
# DEVNEST_EC2_BOOTSTRAP_PREBAKED=true
#
# -----------------------------------------------------------------------------
# Debugging (disable after troubleshooting — do not log secrets)
# -----------------------------------------------------------------------------
# DEVNEST_AUTH_DIAGNOSTICS=true
DEVNEST_AUTOSCALER_ENABLED=true
DEVNEST_AUTOSCALER_LOOP_ENABLED=true
DEVNEST_AUTOSCALER_LOOP_INTERVAL_SECONDS=15
DEVNEST_EC2_REGION=us-east-1
DEVNEST_EC2_AMI_ID=<your-amazon-linux-2023-ami>
DEVNEST_EC2_SUBNET_ID=<your-private-subnet-id>
DEVNEST_EC2_SECURITY_GROUP_IDS=<your-execution-node-security-group-id>
DEVNEST_EC2_INSTANCE_TYPE=t3.medium
DEVNEST_WORKSPACE_CONTAINER_IMAGE=<your-image>
# code-server auth is disabled by default because DevNest gateway/session auth gates access.
# Optional: set DEVNEST_WORKSPACE_AUTH_MODE=password and provide DEVNEST_WORKSPACE_PASSWORD.
DEVNEST_WORKSPACE_AUTH_MODE=none
# DEVNEST_WORKSPACE_PASSWORD=
