NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
#
# Server-side Next.js (API routes) → FastAPI resolution (see frontend/lib/server/internal-api-base.ts):
# - next dev on the host: uses NEXT_PUBLIC_API_BASE_URL (INTERNAL_API_BASE_URL with hostname "backend" is ignored).
# - Frontend container (integration / EC2 image): INTERNAL_API_BASE_URL or default http://backend:8000;
#   loopback INTERNAL_API_BASE_URL is rewritten to backend:8000 inside the container.
#
# Local `next dev`: do NOT set INTERNAL_API_BASE_URL=http://backend:8000 unless you also have that hostname
# (docker-compose.dev.yml only runs Postgres — no API on the Compose network).
# INTERNAL_API_BASE_URL=
#
# Temporary auth/RDS debugging: set DEVNEST_AUTH_DIAGNOSTICS=true on frontend **and** backend, then
# GET http://localhost:3000/api/internal/devnest-diagnostics (see backend observability route).
# DEVNEST_AUTH_DIAGNOSTICS=
