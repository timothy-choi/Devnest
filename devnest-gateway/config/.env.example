# Copy to ../.env in devnest-gateway/ (same directory as docker-compose.yml) if desired.
# Docker Compose reads variables from the shell environment or a project `.env` file.

# Base domain for workspace hostnames: <workspace_id>.<DEVNEST_BASE_DOMAIN>
DEVNEST_BASE_DOMAIN=app.devnest.local

# Published HTTP port for Traefik entrypoint `web` (host → container 80).
DEVNEST_GATEWAY_PORT=80

# Traefik dashboard (insecure; dev only). TODO: disable or protect in production.
DEVNEST_DASHBOARD_PORT=8080

# TODO: When TLS is in scope:
# DEVNEST_GATEWAY_TLS_ENABLED=true
# DEVNEST_ACME_EMAIL=...
# DEVNEST_ACME_CA_SERVER=...
