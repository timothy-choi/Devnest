# Template: same router as the tracked ``051-api-https-letsencrypt.yml``.
# Restore from this file if the active YAML is removed or corrupted.
#
# Prerequisites:
#   - ``050-api-public.yml`` loaded (defines ``devnest-backend-api`` service).
#   - ``certificatesResolvers.letsencrypt`` in ``traefik.yml`` with DEVNEST_ACME_EMAIL set on the Traefik container.
#   - Traefik publishes host ``443:443`` (tlsChallenge). ``80:80`` is optional for HTTP-01 or plain HTTP API.
#   - DNS: api.devnest-app.com → EC2 public IP (Cloudflare: DNS only / grey cloud while debugging TLS).
#
# tlsChallenge uses the ``websecure`` (:443) entrypoint only — no public :80 strictly required for ACME.

http:
  routers:
    devnest-api-public-https:
      rule: "Host(`api.devnest-app.com`)"
      entryPoints:
        - websecure
      service: devnest-backend-api
      tls:
        certResolver: letsencrypt
