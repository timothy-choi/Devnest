# Copy to `.env` next to docker-compose.yml (optional — Compose substitutes these automatically).
# See README.md for local hostname (/etc/hosts) setup.

# Base domain for workspace-style hosts: <id-or-label>.<DEVNEST_BASE_DOMAIN>
# Example routes in traefik/dynamic.yml use: ws-123.app.devnest.local, whoami.app.devnest.local
DEVNEST_BASE_DOMAIN=app.devnest.local

# Host port → Traefik entrypoint `web` (container 80)
DEVNEST_GATEWAY_PORT=80

# Traefik dashboard (insecure — dev only). TODO: disable or lock down in production.
DEVNEST_DASHBOARD_PORT=8080

# Documented default for the ws-123 example upstream (edit traefik/dynamic.yml if you change port).
DEVNEST_WORKSPACE_EXAMPLE_UPSTREAM_PORT=8080

# Loopback IP for scripts/hosts-snippet.sh
DEVNEST_GATEWAY_LOOPBACK_IP=127.0.0.1

# TODO: TLS phase
# DEVNEST_GATEWAY_TLS_ENABLED=false
