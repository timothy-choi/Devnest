# Copy to `.env` next to docker-compose.yml (optional — Compose substitutes these automatically).
# See README.md for local hostname (/etc/hosts) setup.

# Base domain for workspace-style hosts: <id-or-label>.<DEVNEST_BASE_DOMAIN>
# Static examples in traefik/dynamic/000-base.yml: ws-123.app.devnest.local, whoami.app.devnest.local
DEVNEST_BASE_DOMAIN=app.devnest.local

# Host port → Traefik entrypoint `web` (container 80)
DEVNEST_GATEWAY_PORT=80

# Host port → Traefik entrypoint `websecure` (container 443). Active when DEVNEST_TLS_ENABLED=true.
DEVNEST_GATEWAY_TLS_PORT=443

# Traefik dashboard (insecure — dev only). Disable or add BasicAuth in production.
DEVNEST_DASHBOARD_PORT=8080

# Route-admin API (backend registers routes here). Default 9080 avoids clashing with dashboard :8080.
DEVNEST_ROUTE_ADMIN_PORT=9080

# Documented default for the ws-123 example upstream (edit traefik/dynamic/000-base.yml if you change port).
DEVNEST_WORKSPACE_EXAMPLE_UPSTREAM_PORT=8080

# Loopback IP for scripts/hosts-snippet.sh
DEVNEST_GATEWAY_LOOPBACK_IP=127.0.0.1

# --- Backend (control plane) env — set in backend .env, not required for gateway-only compose ---
# DEVNEST_GATEWAY_URL=http://127.0.0.1:9080
# DEVNEST_GATEWAY_ENABLED=true
# DEVNEST_BASE_DOMAIN=app.devnest.local

# ── TLS / HTTPS ────────────────────────────────────────────────────────────────────────────────
# Set DEVNEST_TLS_ENABLED=true to enable the websecure (:443) entrypoint.
# Local/dev: Traefik generates a self-signed certificate automatically (no extra config needed).
# Production: configure certificatesResolvers in traefik/traefik.yml and set DEVNEST_ACME_EMAIL.
DEVNEST_TLS_ENABLED=false
# DEVNEST_ACME_EMAIL=you@example.com   # Required when using Let's Encrypt in production

# ── Gateway ForwardAuth ────────────────────────────────────────────────────────────────────────
# When true, workspace routes require a valid X-DevNest-Workspace-Session token from the client.
# The backend /internal/gateway/auth endpoint validates the token via Traefik ForwardAuth.
# Must also set DEVNEST_GATEWAY_AUTH_ENABLED=true in the backend .env.
DEVNEST_GATEWAY_AUTH_ENABLED=false
# URL of the backend ForwardAuth endpoint reachable from within the Traefik container.
# Typically http://host.docker.internal:<BACKEND_PORT>/internal/gateway/auth
DEVNEST_BACKEND_AUTH_URL=http://host.docker.internal:8000/internal/gateway/auth
