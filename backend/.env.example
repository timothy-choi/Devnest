DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

# OAuth: host:port is OK (http:// added automatically). Or full URL, no trailing slash.
# GitHub callback: {GITHUB_OAUTH_PUBLIC_BASE_URL}/auth/oauth/github/callback
GITHUB_OAUTH_PUBLIC_BASE_URL=localhost:8000
# Google callback: {GCLOUD_OAUTH_PUBLIC_BASE_URL}/auth/oauth/google/callback
GCLOUD_OAUTH_PUBLIC_BASE_URL=localhost:8000
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
